{
    "name": "nafcode/laravel-snapshot-backup",
    "description": "rsync-based snapshot backup for Laravel — file snapshots with hard-linking, hourly DB dumps, multi-disk mirroring, restore and retention commands.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Nasrin Afroz Kakoli",
            "homepage": "https://github.com/NasrinAfrozKakoli",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/NafCode/laravel-snapshot-backup",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/console": "^10.0|^11.0",
        "illuminate/queue": "^10.0|^11.0",
        "illuminate/notifications": "^10.0|^11.0",
        "illuminate/database": "^10.0|^11.0",
        "symfony/process": "^6.0|^7.0",
        "spatie/laravel-medialibrary": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "SnapshotBackup\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SnapshotBackup\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SnapshotBackup\\SnapshotBackupServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
